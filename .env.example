# Server Configuration
PORT=5000
NODE_ENV=development

# Database Setup
# Default local MongoDB database name is cms_database
MONGODB_URI=mongodb://localhost:27017/cms_database

# Security token
JWT_SECRET=your_jwt_secret_token_here_change_in_production

# Cloudinary Integration (Optional: missing values triggers disk upload fallback)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
